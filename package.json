{
  "name": "groute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@groute/web",
    "dev:mobile": "turbo dev --filter=@groute/mobile",
    "build": "turbo build",
    "build:web": "turbo build --filter=@groute/web",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @groute/shared db:generate",
    "db:push": "pnpm --filter @groute/shared db:push"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
